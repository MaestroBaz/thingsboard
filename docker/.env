# Queue type for ThingsBoard
# Options include kafka or other supported queue types
TB_QUEUE_TYPE=kafka

# Cache configuration for ThingsBoard
# Options: redis, redis-cluster, redis-sentinel
CACHE=redis

# Docker repository where ThingsBoard images are stored
DOCKER_REPO=thingsboard
# Uncomment below to use a local Docker repository
# DOCKER_REPO=local

# Docker image names for various ThingsBoard services
JS_EXECUTOR_DOCKER_NAME=tb-js-executor
TB_NODE_DOCKER_NAME=tb-node
WEB_UI_DOCKER_NAME=tb-web-ui
MQTT_TRANSPORT_DOCKER_NAME=tb-mqtt-transport
HTTP_TRANSPORT_DOCKER_NAME=tb-http-transport
COAP_TRANSPORT_DOCKER_NAME=tb-coap-transport
LWM2M_TRANSPORT_DOCKER_NAME=tb-lwm2m-transport
SNMP_TRANSPORT_DOCKER_NAME=tb-snmp-transport
TB_VC_EXECUTOR_DOCKER_NAME=tb-vc-executor

# ThingsBoard version tag
TB_VERSION=latest

# Database configuration
# Options: postgres (PostgreSQL) or hybrid (PostgreSQL for entities, Cassandra for timeseries)
DATABASE=postgres

# Name for the load balancer service
LOAD_BALANCER_NAME=haproxy-certbot

# Enable or disable monitoring services (Prometheus and Grafana)
MONITORING_ENABLED=false

# Java options to limit memory usage for ThingsBoard services
# Example: -Xmx2048M -Xms2048M -Xss384k -XX:+AlwaysPreTouch
JAVA_OPTS=

# Volume names for log storage (set to avoid warnings in Docker Compose)
# Configuration volume
TB_CONFIG_VOLUME=tb-config-volume
# General log volume
TB_LOG_VOLUME=tb-log-volume
# Log volume for CoAP Transport service
TB_COAP_TRANSPORT_LOG_VOLUME=tb-coap-transport-log-volume
# Log volume for LwM2M Transport service
TB_LWM2M_TRANSPORT_LOG_VOLUME=tb-lwm2m-transport-log-volume
# Log volume for HTTP Transport services
TB_HTTP_TRANSPORT_LOG_VOLUME=tb-http-transport-log-volume
# Log volume for MQTT Transport services
TB_MQTT_TRANSPORT_LOG_VOLUME=tb-mqtt-transport-log-volume
# Log volume for SNMP Transport service
TB_SNMP_TRANSPORT_LOG_VOLUME=tb-snmp-transport-log-volume
# Log volume for Video Call Executor service
TB_VC_EXECUTOR_LOG_VOLUME=tb-vc-executor-log-volume
# Postgres database volume
POSTGRES_DATA_VOLUME=postgres_db_volume

TB_COAP_TRANSPORT_CONFIG_VOLUME=tb-coap-transport-config-volume
TB_LWM2M_TRANSPORT_CONFIG_VOLUME=tb-lwm2m-transport-config-volume
TB_HTTP_TRANSPORT_CONFIG_VOLUME=tb-http-transport-config-volume
TB_MQTT_TRANSPORT_CONFIG_VOLUME=tb-mqtt-transport-config-volume
TB_SNMP_TRANSPORT_CONFIG_VOLUME=tb-snmp-transport-config-volume
TB_VC_EXECUTOR_CONFIG_VOLUME=tb-vc-executor-config-volume